{
  "name": "@clan-world/shared",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters/index.ts",
    "./generated/*": "./src/generated/*.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "codegen": "pnpm -w gen:chainclient-abi",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint stub'",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@clan-world/contract-types": "workspace:*",
    "@clan-world/contracts": "workspace:*",
    "convex": "1.17.4",
    "viem": "^2.48.4"
  }
}
