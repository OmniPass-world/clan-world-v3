{
  "name": "clan-world",
  "private": true,
  "version": "2.2.0",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "build": "turbo run build",
    "codegen": "pnpm gen:constants && turbo run codegen",
    "dev": "turbo run dev",
    "gen:chainclient-abi": "node scripts/gen-chainclient-abi.mjs",
    "gen:contract-abi": "node scripts/gen-contract-abi.mjs",
    "gen:constants": "node scripts/gen-constants.mjs",
    "gen:enums": "node scripts/gen-enums.mjs",
    "check:abi": "pnpm --dir packages/contracts run check:abi && pnpm test:chainclient-abi",
    "lint": "turbo run lint",
    "test:chainclient-abi": "node scripts/gen-chainclient-abi.mjs --check",
    "test:abi-parity": "node packages/shared/scripts/check-chain-abi-parity.mjs",
    "test": "pnpm test:abi-parity && turbo run test",
    "test:e2e": "playwright test --config apps/web/playwright.config.ts",
    "test:e2e:ui": "playwright test --config apps/web/playwright.config.ts --ui",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "25.6.0",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript": "5.9.3",
    "viem": "^2.48.7"
  }
}
