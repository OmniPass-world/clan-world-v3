{
  "name": "clan-world",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "gen:chainclient-abi": "node scripts/gen-chainclient-abi.mjs",
    "lint": "turbo run lint",
    "test:chainclient-abi": "node scripts/gen-chainclient-abi.mjs --check",
    "test": "turbo run test",
    "test:e2e": "playwright test --config apps/web/playwright.config.ts",
    "test:e2e:ui": "playwright test --config apps/web/playwright.config.ts --ui",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "25.6.0",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript": "5.9.3"
  }
}
