{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "env": {
    "TZ": "America/New_York"
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(elder *)",
      "Bash(date)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git *)",
      "Bash(systemctl *)",
      "Bash(sudo *)",
      "WebFetch",
      "WebSearch"
    ]
  }
}
