{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "env": {
    "TZ": "America/New_York"
  },
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": "deny",
    "allow": [
      "Bash(elder *)",
      "Bash(date)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "WebFetch",
      "WebSearch"
    ]
  }
}
