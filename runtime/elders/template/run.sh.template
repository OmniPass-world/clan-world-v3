#!/usr/bin/env bash
# elder-{{ELDER_NUMBER}} entry point — adapted from ~/agents/_template/run.sh
# Pattern A per back-on-plan §1A: shared parent .claude/ at ~/clan-world/.claude/
# is the single Claude config dir for every Elder. Each Elder still runs from
# its own working directory for local .env, state, and outbox files.

set -euo pipefail

ELDER_NUMBER={{ELDER_NUMBER}}
AGENT_DIR="$(cd "$(dirname "$0")" && pwd)"
RUNTIME_DIR="$(cd "$AGENT_DIR/.." && pwd)"

# === Core config — shared Claude config dir for all Elders ===
# NEVER use ANTHROPIC_API_KEY, NEVER use --bare (forces API key).
export CLAUDE_CONFIG_DIR="$RUNTIME_DIR/.claude"
export CLAUDE_CODE_HIDE_ACCOUNT_INFO=1

# === Token-based auth (skips interactive OAuth wizard) ===
# CLAUDE_CODE_OAUTH_TOKEN env var avoids the per-elder wizard dance.
# Token is shared across all elders (tied to user's MAX subscription).
# Stored in ~/code/clan-world/.env.local (gitignored).
if [ -f "${CLAN_WORLD_REPO:-$HOME/code/clan-world}/.env.local" ]; then
  set -a
  # shellcheck disable=SC1091
  source "${CLAN_WORLD_REPO:-$HOME/code/clan-world}/.env.local"
  set +a
fi
if [ -f "$AGENT_DIR/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$AGENT_DIR/.env"
  set +a
fi

# OAuth credentials: symlink to host-shared credentials so token refresh stays fresh.
# Run once during agent setup if not already present:
mkdir -p "$CLAUDE_CONFIG_DIR"
if [ ! -e "$CLAUDE_CONFIG_DIR/.credentials.json" ]; then
  ln -sf ~/.claude/.credentials.json "$CLAUDE_CONFIG_DIR/.credentials.json" || true
fi

# === Plugin isolation (Telegram unused for Elders, but isolation matters) ===
export TELEGRAM_STATE_DIR="$AGENT_DIR/state/channels/telegram"
export CLAUDE_CODE_PLUGIN_CACHE_DIR="$AGENT_DIR/state/plugin-cache"

# === Runtime state dirs ===
mkdir -p "$AGENT_DIR/state/plugin-cache" "$AGENT_DIR/state/outbox"

# === Identity ===
export AGENT_NAME="elder-$ELDER_NUMBER"
export AGENT_ROLE="ClanWorld Elder (clan $ELDER_NUMBER)"
export ELDER_NUMBER
# Elder CLI expects ELDER_N (memory/peer/ack-clear subcommands key by it).
export ELDER_N="$ELDER_NUMBER"

# === Model: Sonnet 4.6 default; override via env if Liam wants Opus for strategic depth ===
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-claude-sonnet-4-6}"

# === Time zone ===
export TZ="America/New_York"

# === Elder CLI on PATH ===
# The runner injects situation blocks; Elders respond by calling `elder` subcommands
# (world snapshot, clan view, market actions, peer whispers, memory save, ack-clear).
# Binary lives in the clan-world workspace; symlink/PATH avoids hardcoding repo paths in skills.
export PATH="$HOME/code/omnipass-world/clan-world/packages/agents/bin:$PATH"

# === CWD stays per-Elder; CLAUDE_CONFIG_DIR is shared ===
cd "$AGENT_DIR"
echo "[$AGENT_NAME] Starting... model=$ANTHROPIC_MODEL $(date '+%Y-%m-%d %H:%M:%S %Z')"

# Elders don't need the Telegram plugin (no inbound Telegram), so omit --channels.
# The runner injects situation blocks via tmux send-keys directly to this REPL.
exec claude "$@"
