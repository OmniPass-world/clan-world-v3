# Per-elder secrets template — copy to agents/elder-1/.env (gitignored) and fill in values before bring-up.
#
# docker compose reads this file via `env_file:` directive in agents/docker-compose.elders.yml,
# injecting these vars into the elder-1 container's environment. The .env file itself is NOT
# bind-mounted into the container, so even with a misconfigured deny rule the agent's Bash tool
# cannot `cat /agent/.env`.

# CC harness OAuth token — get from `claude login` on a host with browser access, then copy
# the resulting ~/.claude/.credentials.json's oauth token here.
ANTHROPIC_OAUTH_TOKEN=

# Stable identity for this elder. The CC harness, Convex bus, and the `elder` CLI all key on
# ELDER_ID. Do NOT change between deploys — bus history, peer inboxes, and on-chain wallet
# assignment all anchor on this string.
ELDER_ID=elder-1

# Numeric clan ID this elder controls. Maps to the on-chain ClanId in the contract.
# clan-1 = Forest (baseRegion=1); see agents/shared/home-claude/CLAUDE.md for the full mapping.
CLAN_ID=1

# Shared HMAC secret for the Convex command bus. Generated by `make bootstrap-bus-secrets`
# (Phase 1.8). Used to sign elder-side bus operations so the orchestrator can verify
# command delivery + result acks came from this elder, not a spoofed client.
BUS_ELDER_SECRET=
