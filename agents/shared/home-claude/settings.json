{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Shared CC permission base for every Elder container. Bind-mounted R/O at /home/elder/.claude/settings.json. Deny rules apply to the agent's tool calls (Read/Write/Edit/Bash), NOT the CC harness itself — the harness still reads/writes credentials and project state to run normally. NOTE: absolute filesystem paths use the `//path` double-slash convention per CC permissions docs (single leading slash is interpreted as project-relative). Tilde-expanded `~/.claude/...` and double-slash `//home/elder/.claude/...` both listed to defeat path-resolution variance.",
  "permissions": {
    "deny": [
      "Read(.credentials.json)",
      "Read(~/.claude/.credentials.json)",
      "Read(//home/elder/.claude/.credentials.json)",
      "Read(~/.claude/projects/**/sessions/*.jsonl)",
      "Read(//home/elder/.claude/projects/**/sessions/*.jsonl)",
      "Bash(cat ~/.claude/.credentials.json)",
      "Bash(cat //home/elder/.claude/.credentials.json)",
      "Bash(cat ~/.claude/projects/*/sessions/*.jsonl)",
      "Bash(cat //home/elder/.claude/projects/*/sessions/*.jsonl)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(cat //proc/*/environ)",
      "Bash(cat //agent/.env)",
      "Bash(cat //home/elder/.env)",
      "Read(/run/secrets/**)",
      "Read(//run/secrets/**)",
      "Bash(cat /run/secrets/*)",
      "Bash(cat //run/secrets/*)",
      "Bash(ls /run/secrets/*)",
      "Bash(ls //run/secrets/*)",
      "Bash(strings *)",
      "Bash(set)",
      "Bash(declare *)",
      "Bash(export)",
      "Bash(node -e *)",
      "Bash(python3 -c *)",
      "Bash(python -c *)",
      "Write(~/.claude/settings.json)",
      "Write(//home/elder/.claude/settings.json)",
      "Write(~/.claude/CLAUDE.md)",
      "Write(//home/elder/.claude/CLAUDE.md)",
      "Edit(~/.claude/settings.json)",
      "Edit(//home/elder/.claude/settings.json)",
      "Edit(~/.claude/CLAUDE.md)",
      "Edit(//home/elder/.claude/CLAUDE.md)"
    ],
    "allow": [
      "Read(~/.claude/CLAUDE.md)",
      "Read(//home/elder/.claude/CLAUDE.md)",
      "Read(~/.claude/skills/**)",
      "Read(//home/elder/.claude/skills/**)",
      "Read(~/.claude/projects/*/memory/**)",
      "Read(//home/elder/.claude/projects/*/memory/**)",
      "Write(~/.claude/projects/*/memory/**)",
      "Write(//home/elder/.claude/projects/*/memory/**)",
      "Edit(~/.claude/projects/*/memory/**)",
      "Edit(//home/elder/.claude/projects/*/memory/**)",
      "Read(//workspace/**)",
      "Write(//workspace/**)",
      "Edit(//workspace/**)",
      "Read(//workspace/ANCIENT_WISDOM.md)",
      "Write(//workspace/ANCIENT_WISDOM.md)",
      "Edit(//workspace/ANCIENT_WISDOM.md)",
      "Read(//tmp/**)",
      "Write(//tmp/**)",
      "Edit(//tmp/**)",
      "Bash(elder *)",
      "Bash(date)",
      "Bash(date *)"
    ]
  }
}
