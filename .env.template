# ClanWorld env template.
# Do not commit .env. Copy to .env.local (gitignored) and fill values.
#
# Two sections:
#   - Server-only: read by Node/tsx processes (keeper, narrator, webhook). Never sent to browser.
#   - Browser (Vite): MUST be prefixed with VITE_ to be included in Vite bundles.
#     readEnv() in _env.ts tries both bare and VITE_-prefixed names so callers use
#     the same key regardless of runtime context.

# ============================================================
# Server-only (Node / tsx — NOT exposed to browser bundle)
# ============================================================

# --- Chain ---
CHAIN=worldchain-sepolia
RPC_URL_PRIMARY=
RPC_URL_FALLBACK=

# --- Convex backend ---
CONVEX_URL=

# --- LLM (Submission 1 Elders use Claude Code OAuth sessions; this is for narrator/utility uses) ---
ANTHROPIC_API_KEY=

# --- World mini app (server-side World ID verify, webhook secret) ---
# Server-side base name; browser variant is VITE_WORLD_APP_ID below. ONE concept.
WORLD_APP_ID=

# --- Tick + heartbeat ---
TICK_DURATION_MS=20000
KEEPER_MODE=foundry-loop
HEARTBEAT_CALLER_ENABLED=false
WEBHOOK_SHARED_SECRET=

# ============================================================
# Browser (Vite) — MUST be VITE_-prefixed to reach the bundle
# ============================================================

# Adapter toggles (true => stub impl, false/unset => real impl)
VITE_CLAN_WORLD_USE_STUB_CHAIN=true
VITE_CLAN_WORLD_USE_STUB_CONVEX=true
VITE_CLAN_WORLD_USE_STUB_LLM=true

# World mini app client-facing IDs
VITE_WORLD_APP_ID=
VITE_WORLD_ACTION_ID=

# Set to 'true' to bypass the "Open in World App" guard (for demo recording / judges testing in regular browser)
VITE_DEMO_BYPASS_WORLD_GUARD=

# ============================================================
# Runner daemon (packages/runner) — Cycle A + Cycle B per Elder
# ============================================================

# Claude Code OAuth Token for Elders
# Run `claude setup-token` to get one.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-xxx

# Active elder slot when running single-elder CLI mode (1-4). Multi-elder
# runner ignores this and spawns instances for ELDER_IDS=[1,2,3,4].
ELDER_N=

# 12-word BIP-39 mnemonic for the Elder wallets. HD-derived per ELDER_INDEX.
# In .env.local only; never commit. Path: ~/.secrets/clanworld-elder-wallets.json
ELDER_MNEMONIC=

# Per-elder index into the HD derivation path (0-3 for Elders 1-4).
ELDER_INDEX=

# Per-elder clan-id mappings (used by FilePeerInbox + AxlPeerInbox routing).
# When set, inbox key = elder slot; when unset, sender clan id is used verbatim.
ELDER_1_CLAN_ID=
ELDER_2_CLAN_ID=
ELDER_3_CLAN_ID=
ELDER_4_CLAN_ID=

# 0G memory adapter — set OG_STORAGE_API_KEY to ANY non-empty value to enable
# 0G KV mode. Currently a feature flag, NOT used for SDK auth (auth comes from
# ELDER_MNEMONIC-derived wallets). Empty/unset = falls back to FileMemoryStore.
OG_STORAGE_API_KEY=
OG_STREAM_ID=

# AXL peer transport — set both AXL_API_KEY and AXL_NETWORK_ID to enable AXL
# mode (real peer messaging). Either empty/unset = falls back to FilePeerInbox.
AXL_API_KEY=
AXL_NETWORK_ID=
AXL_NODE_URL=
# Per-elder peer ID lookup table for AXL spoof-rejection — required when AXL
# is enabled. Each elder must have its own AXL peer ID configured.
AXL_PEER_ID_1=
AXL_PEER_ID_2=
AXL_PEER_ID_3=
AXL_PEER_ID_4=

# Runner timing knobs
RUNNER_POLL_INTERVAL_MS=2000
RUNNER_DELIVERY_TIMEOUT_MS=10000
RUNNER_SETTLE_WINDOW_SEC=10
