# ClanWorld env template.
# Do not commit .env. Copy to .env.local (gitignored) and fill values.
#
# Two sections:
#   - Server-only: read by Node/tsx processes (keeper, narrator, webhook). Never sent to browser.
#   - Browser (Vite): MUST be prefixed with VITE_ to be included in Vite bundles.
#     readEnv() in _env.ts tries both bare and VITE_-prefixed names so callers use
#     the same key regardless of runtime context.

# ============================================================
# Server-only (Node / tsx — NOT exposed to browser bundle)
# ============================================================

# --- Chain ---
CHAIN=base-sepolia
# Primary RPC: Alchemy Base Sepolia — replace <YOUR_ALCHEMY_KEY> with your key
RPC_URL_PRIMARY=https://base-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
# Fallback: public Base Sepolia endpoint
RPC_URL_FALLBACK=https://sepolia.base.org
CLAN_WORLD_CONTRACT_ADDRESS=
CLAN_WORLD_LENS_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# --- Convex backend ---
CONVEX_URL=
JUPITER_API_KEY=

# --- Solana Devnet GOLD token / Android wallet txs ---
CLAN_WORLD_GOLD_RPC_URL=https://api.devnet.solana.com
CLAN_WORLD_GOLD_MINT=FPBZJfEgxdkKEeT8pZhLRPg1NzwhyWJRqPKpzRWZLSAF
CLAN_WORLD_GOLD_FAUCET_PROGRAM_ID=aMwXvN227YK14C8eFQzgyk9h7TfkMk1XQkekZXS6WWQ
CLAN_WORLD_GOLD_TREASURY_OWNER=5YqhQK4LfJmaaZQLqSEfcJc4ViUQHX15quVCXwNJDFnd
CLAN_WORLD_GOLD_TREASURY_ATA=4jQN1PfXQ2yfU75K4pMiY4Ue62yXknjKFJ7L9wukSRn8

# --- Tick + heartbeat ---
TICK_DURATION_MS=20000
KEEPER_MODE=foundry-loop
HEARTBEAT_CALLER_ENABLED=false
# Opt-in local/demo fake Convex heartbeat. Leave unset/false for real-deal
# testing and production; v1.1 replaces this with a chain-reader indexer.
CLANWORLD_USE_FAKE_HEARTBEAT=false
WEBHOOK_SHARED_SECRET=

# ============================================================
# Browser (Vite) — MUST be VITE_-prefixed to reach the bundle
# ============================================================

# Adapter toggles (true => stub impl, false/unset => real impl)
VITE_CLAN_WORLD_USE_STUB_CHAIN=true
VITE_CLAN_WORLD_USE_STUB_CONVEX=true
VITE_CLAN_WORLD_USE_STUB_LLM=true

# Demo/dev mode is opt-in. Set to 'true' only when intentionally showing mock
# clans, bandits, walls, and canned travel. Leave unset or 'false' for real
# Convex/chain state.
VITE_CLANWORLD_DEMO_MODE=false

# ============================================================
# Runner daemon (packages/runner) — Cycle A + Cycle B per Elder
# ============================================================

# Claude Code OAuth Token for Elders
# Run `claude setup-token` to get one.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-xxx

# Active elder slot when running single-elder CLI mode (1-4). Multi-elder
# runner ignores this and spawns instances for ELDER_IDS=[1,2,3,4].
ELDER_N=

# 12-word BIP-39 mnemonic for the Elder wallets. HD-derived per ELDER_INDEX.
# In .env.local only; never commit. Path: ~/.secrets/clanworld-elder-wallets.json
ELDER_MNEMONIC=

# Per-elder index into the HD derivation path (0-3 for Elders 1-4).
ELDER_INDEX=

# Per-elder clan-id mappings (used by FilePeerInbox + AxlPeerInbox routing).
# When set, inbox key = elder slot; when unset, sender clan id is used verbatim.
ELDER_1_CLAN_ID=
ELDER_2_CLAN_ID=
ELDER_3_CLAN_ID=
ELDER_4_CLAN_ID=

# 0G memory adapter — set OG_STORAGE_ENABLED to ANY non-empty value to enable
# 0G KV mode. This is a feature flag, NOT a credential. Real auth comes from
# ELDER_MNEMONIC-derived wallets. Empty/unset = falls back to FileMemoryStore.
OG_STORAGE_ENABLED=
OG_STREAM_ID=
OG_STREAM_ID_CLAN_1=
OG_STREAM_ID_CLAN_2=
OG_STREAM_ID_CLAN_3=
OG_STREAM_ID_CLAN_4=
OG_KV_CLIENT_URL=

# 0G iNFT identity plane. The iNFT lives on 0G and is linked to Base clans by
# convention only: tokenId == clanId. No cross-chain owner validation in demo.
ZERO_G_RPC_URL=https://evmrpc.0g.ai
OG_CHAIN_ID=16661
OG_INFT_ADDRESS=
OG_INFT_PRIVATE_KEY=
INFT_OWNER=
INFT_OWNER_PRIVATE_KEY=
INFT_NEW_OWNER=
INFT_TOKEN_ID=
INFT_METADATA_URI=
INFT_TRANSFER_URI=
VITE_ZERO_G_RPC_URL=https://evmrpc.0g.ai
VITE_OG_CHAIN_ID=16661
VITE_OG_INFT_ADDRESS=
VITE_OWNER_EDITOR_ENABLED=true

# AXL peer transport — set both AXL_API_KEY and AXL_NETWORK_ID to enable AXL
# mode (real peer messaging). Either empty/unset = falls back to FilePeerInbox.
AXL_API_KEY=
AXL_NETWORK_ID=
AXL_NODE_URL=
# Per-elder peer ID lookup table for AXL spoof-rejection — required when AXL
# is enabled. Each elder must have its own AXL peer ID configured.
AXL_PEER_ID_1=
AXL_PEER_ID_2=
AXL_PEER_ID_3=
AXL_PEER_ID_4=

# Runner timing knobs
RUNNER_POLL_INTERVAL_MS=2000
RUNNER_DELIVERY_TIMEOUT_MS=10000
RUNNER_SETTLE_WINDOW_SEC=10
