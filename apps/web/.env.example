# ClanWorld web env example.
# Copy to .env.local (gitignored) and fill values.
# Place at the monorepo root (envDir in vite.config.ts resolves there).

# ============================================================
# Browser (Vite) — MUST be VITE_-prefixed to reach the bundle
# ============================================================

# Convex backend URL
VITE_CONVEX_URL=

# Demo/dev mode is opt-in.
# true = show mock clans, bandits, walls, canned travel (dev UX preserved)
# false/unset = render real Convex/chain state; empty world stays empty
VITE_CLANWORLD_DEMO_MODE=false
