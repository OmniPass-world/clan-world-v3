{
  "expo": {
    "name": "Clan World",
    "slug": "clan-world-mobile",
    "version": "0.1.0",
    "scheme": "clanworld",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "icon": "./assets/logo-main-square.png",
    "splash": {
      "image": "./assets/logo-main-square.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0A0E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "android"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "army.shib.clanworld"
    },
    "android": {
      "package": "army.shib.clanworld",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-main-square.png",
        "backgroundColor": "#0B0A0E"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#D4AF5C"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b4091d11-daf2-4f15-aee2-984f70198a9d"
      }
    }
  }
}
