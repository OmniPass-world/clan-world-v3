{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "codegen": {
      "dependsOn": ["^codegen"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!abi/IClanWorld.json",
        "!abi/IClanWorldLens.json",
        "!abi/IDiamondLoupe.json",
        "!abi/IDiamondCut.json",
        "!abi/OwnershipFacet.json",
        "!convex/_generated/**"
      ],
      "outputs": [
        "abi/IClanWorld.json",
        "abi/IClanWorldLens.json",
        "abi/IDiamondLoupe.json",
        "abi/IDiamondCut.json",
        "abi/OwnershipFacet.json",
        "src/adapters/IChainClient.ts",
        "src/generated/constants.ts",
        "src/generated/enums.ts",
        "convex/_generated/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
