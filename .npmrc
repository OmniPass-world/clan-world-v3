enable-pre-post-scripts=true
auto-install-peers=true

# Hoist Expo / React Native deps so expo-modules-autolinking can resolve them
# from the apps/mobile package. Without this, EAS gradle build fails with:
#   PackageList.java: cannot find symbol class ExpoModulesPackage
# The pattern-based hoist keeps all other v3 packages on the default isolated
# layout — only deps matching these patterns are lifted to the workspace root.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=*@expo*
# Bare `react` and `react-dom` must be hoisted too — without this, deeply
# nested pnpm packages (expo-modules-core, etc.) resolve `require('react')`
# from a different physical path than apps/mobile does, producing two copies
# of React in Metro's bundle. Symptom: "Objects are not valid as a React
# child (found: object with keys {$$typeof, type, key, props, _owner, _store})"
# because React 18's element symbol differs from React 19's, and the bundle
# ends up with both.
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=scheduler
