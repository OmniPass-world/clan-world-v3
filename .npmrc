enable-pre-post-scripts=true
auto-install-peers=true

# Hoist Expo / React Native deps so expo-modules-autolinking can resolve them
# from the apps/mobile package. Without this, EAS gradle build fails with:
#   PackageList.java: cannot find symbol class ExpoModulesPackage
# The pattern-based hoist keeps all other v3 packages on the default isolated
# layout — only deps matching these patterns are lifted to the workspace root.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=*@expo*
